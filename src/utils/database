// src/utils/database.ts

import { createClient } from 'supabase';

// Fallback values for environment variables
const DEFAULT_SUPABASE_URL = 'https://your-supabase-project-url.supabase.co';
const DEFAULT_SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...';

// Validate and parse environment variables with fallbacks
const validateEnv = () => {
  const supabaseUrl = process.env.SUPABASE_URL || DEFAULT_SUPABASE_URL;
  const supabaseKey = process.env.SUPABASE_KEY || DEFAULT_SUPABASE_KEY;

  // Basic validation
  if (!supabaseUrl.includes('.supabase.co')) {
    console.warn('Supabase URL format is not ideal, using fallback');
    return { supabaseUrl: DEFAULT_SUPABASE_URL, supabaseKey };
  }

  if (!supabaseKey.startsWith('eyJ')) {
    console.warn('Supabase key format is not ideal, using fallback');
    return { supabaseUrl, supabaseKey: DEFAULT_SUPABASE_KEY };
  }

  return { supabaseUrl, supabaseKey };
};

// Initialize Supabase client with fallback mechanism
export const supabaseClient = (() => {
  try {
    const { supabaseUrl, supabaseKey } = validateEnv();
    return createClient(supabaseUrl, supabaseKey);
  } catch (error) {
    console.error('Failed to initialize Supabase client:', error);
    // Fallback to default client
    return createClient(DEFAULT_SUPABASE_URL, DEFAULT_SUPABASE_KEY);
  }
})();